# Foundry MCP (headless) — environment configuration
#
# Copy this to a gitignored `.env` in the repo root and fill in YOUR instance's values.
# config.ts reads every variable below; anything left unset falls back to the neutral
# placeholders/defaults shown here. Real values (and ALL secrets) belong only in .env.

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=simple
ENABLE_FILE_LOGGING=false
# LOG_FILE_PATH=./logs/mcp-server.log
# TOOL_RESPONSE_MAX_CHARS=20000

# =============================================================================
# MCP server identity
# =============================================================================
SERVER_NAME=foundry-mcp-server
# SERVER_VERSION=1.0.0

# =============================================================================
# Headless Foundry bridge (Plane A — src/foundry.ts)
# =============================================================================
# Your world's base URL, e.g. https://your-server.moltenhosting.com
MOLTEN_SERVER_URL=https://your-server.moltenhosting.com
# The world's id (folder name under Data/worlds; this is the "molten id"). With MOLTEN_ADMIN_KEY set,
# the bridge will remote-LAUNCH this world if it finds the box up but no world active. Leave unset to
# keep world-launch a manual step (the bridge then tells you to launch it instead of trying).
# TIP: you don't need to be told the world id — read it over WebDAV. PROPFIND Depth:1
#   https://<box>.webdav.moltenhosting.com/Data/worlds/  (Basic auth: foundry-ftp / File-Manager pw)
# and every collection under worlds/ (other than README.txt) is a world id. An empty worlds/ means the
# box is fresh with no world yet.
MOLTEN_WORLD_ID=your-world
# Dedicated Foundry user the headless client joins as.
FOUNDRY_USER=MCP-Claude
# That user's password. Leave unset/blank for a passwordless user.
# FOUNDRY_PASSWORD=
# Molten "Server Startup / Magic URL" (…?s=token) — GET to wake a sleeping box before joining.
# Optional but recommended; without it the box must already be awake. Read it from the Molten panel.
# MOLTEN_MAGIC_URL=

# =============================================================================
# Molten file tools (Plane B — WebDAV; DESIGN §4/§6)
# =============================================================================
MOLTEN_WEBDAV_URL=https://your-server.webdav.moltenhosting.com
MOLTEN_FILEBROWSER_URL=https://your-server.files.moltenhosting.com
# Identical for every Molten instance:
MOLTEN_WEBDAV_USER=foundry-ftp

# =============================================================================
# SECRETS — read once from the Molten panel (Server Details), NEVER commit.
# Leave blank here; set the real values only in your gitignored .env.
# Each tool reports which variable to set if its secret is missing.
# =============================================================================
MOLTEN_WEBDAV_PASSWORD=    # upload-asset / asset file ops: File Manager password (user = foundry-ftp)
MOLTEN_ADMIN_KEY=          # Foundry "Default Administrator Password" (admin access key).
                           # With MOLTEN_WORLD_ID, lets the bridge remote-launch a world on a cold box.
